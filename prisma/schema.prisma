generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [uuid_ossp(map: "uuid-ossp", schema: "extensions"), vector]
}

model Organization {
  id             String     @id @default(cuid())
  name           String
  logoUrl        String?    // URL or path to org logo
  primaryColor   String?    // e.g. "#4a90a4"
  secondaryColor String?    // e.g. "#7C3AED"
  maxSeats       Int        @default(5)   // licence seat limit
  billingEmail   String?    // billing contact email
  adminName      String?    // admin contact first name (used in onboarding email)
  isSystem       Boolean    @default(false) @map("is_system")  // platform-owned org (e.g. holds demo/example workshops); hidden from tenant-facing org lists
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  users          User[]
  workshops      Workshop[]
  execLicences   ExecLicence[]

  @@map("organizations")
}

model User {
  id               String       @id @default(cuid())
  email            String       @unique
  name             String
  password         String       // bcrypt hashed password
  mustChangePassword Boolean    @default(false) @map("must_change_password")
  role             UserRole     @default(TENANT_ADMIN)
  organizationId   String?      // NULL for platform admins
  isActive         Boolean      @default(true)
  lastLoginAt      DateTime?
  failedLoginCount Int          @default(0)
  lockedUntil      DateTime?
  // TOTP MFA fields (ISO 27001 A.9.4.2 / SOC 2 CC6.1)
  // totpSecret is AES-256 encrypted at rest via lib/encryption.ts
  totpSecret       String?      @map("totp_secret")          // encrypted TOTP secret
  totpEnabled      Boolean      @default(false) @map("totp_enabled")
  totpVerifiedAt   DateTime?    @map("totp_verified_at")     // when setup was completed
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  organization     Organization? @relation(fields: [organizationId], references: [id])
  createdWorkshops Workshop[]
  workshopShares   WorkshopShare[]
  loginAttempts    LoginAttempt[]
  sessions         Session[]
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

enum UserRole {
  PLATFORM_ADMIN  // Can see all organizations
  TENANT_ADMIN    // Can only see their organization; can manage sub-users
  TENANT_USER     // Can run workshops but cannot manage users
}

model LoginAttempt {
  id          String   @id @default(cuid())
  userId      String?  // NULL if user not found
  email       String
  ipAddress   String?
  userAgent   String?
  success     Boolean
  failureReason String?
  createdAt   DateTime @default(now())
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, createdAt])
  @@index([success, createdAt])
  @@map("login_attempts")
}

model Session {
  id             String    @id @default(cuid())
  userId         String?
  execLicenceId  String?
  token          String    @unique
  userAgent      String?
  ipAddress      String?
  expiresAt      DateTime
  lastActivityAt DateTime  @default(now())
  createdAt      DateTime  @default(now())
  revokedAt      DateTime?
  user           User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@index([userId, expiresAt])
  @@map("sessions")
}

model ExecLicence {
  id             String    @id @default(cuid())
  organizationId String
  email          String    @unique
  hashedPassword String
  name           String
  title          String?
  isActive       Boolean   @default(true)
  lastLoginAt    DateTime?
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@map("exec_licences")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model Workshop {
  id                String                @id @default(cuid())
  organizationId    String
  name              String
  description       String?
  businessContext   String?
  workshopType      WorkshopType          @default(CUSTOM)
  status            WorkshopStatus        @default(DRAFT)
  zoomMeetingId     String?
  createdById       String
  scheduledDate     DateTime?
  responseDeadline  DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  includeRegulation Boolean               @default(true)
  meetingPlan       Json?
  salesReport       Json?
  salesActions      Json?

  // DREAM workshop prep fields
  clientName        String?               @map("client_name")          // e.g. "Tesco", "Barclays"
  industry          String?                                            // e.g. "Retail", "Financial Services"
  companyWebsite    String?               @map("company_website")      // e.g. "https://www.tesco.com"
  dreamTrack        DreamTrack?           @map("dream_track")          // ENTERPRISE or DOMAIN
  targetDomain      String?               @map("target_domain")        // e.g. "Customer Operations" (DOMAIN track only)
  prepResearch      Json?                 @map("prep_research")        // Research Agent output
  customQuestions   Json?                 @map("custom_questions")     // Tailored question set (editable)
  discoveryBriefing Json?                 @map("discovery_briefing")   // Discovery Intelligence Agent synthesis
  discoverAnalysis  Json?                 @map("discover_analysis")    // Organisational Analysis dashboard data
  discoverySummary  Json?                 @map("discovery_summary")    // Cached discovery summary (executive + lenses)

  // DREAM Output Intelligence (5-stage AI pipeline output)
  outputIntelligence  Json?                 @map("output_intelligence")  // WorkshopOutputIntelligence stored as JSON
  reportSummary       Json?                 @map("report_summary")       // ReportSummary: exec summary + solution summary (single GPT-4o call)

  // Field Discovery / Diagnostic extension fields
  engagementType      EngagementType?       @map("engagement_type")      // Diagnostic Baseline, Operational Deep Dive, etc.
  domainPack          String?               @map("domain_pack")          // Key into domain pack registry (e.g. "contact_centre")
  domainPackConfig    Json?                 @map("domain_pack_config")   // Resolved config snapshot at creation time
  discoveryQuestions  Json?                 @map("discovery_questions")  // Per-lens Discovery interview questions (editable)
  blueprint           Json?                 @map("blueprint")            // Composed WorkshopBlueprint snapshot (runtime config)
  historicalMetrics   Json?                 @map("historical_metrics")   // Normalized metric time series from CSV upload
  evidenceSynthesis   Json?                 @map("evidence_synthesis")   // Cross-document synthesis (themes, outliers, contradictions)

  // COM-B Behavioural Interventions (generated layer)
  behaviouralInterventions Json?         @map("behavioural_interventions")

  // Example/demo flag — example workshops are visible to all authenticated users (cross-org)
  // and are read-only. Users must fork to run synthesis on their own copy.
  isExample        Boolean               @default(false) @map("is_example")
  exampleSourceId  String?               @map("example_source_id")  // Set on forks: ID of source example

  insights          ConversationInsight[]
  sessions          ConversationSession[]
  dataPoints        DataPoint[]
  reports           ConversationReport[]
  themes            DiscoveryTheme[]
  liveSnapshots     LiveWorkshopSnapshot[]
  sessionVersions   LiveSessionVersion[]
  eventOutbox       WorkshopEventOutbox[]
  transcriptChunks  TranscriptChunk[]
  thoughtWindows    ThoughtWindow[]
  participants      WorkshopParticipant[]
  scratchpad        WorkshopScratchpad?
  shares            WorkshopShare[]
  captureSessions   CaptureSession[]
  findings          Finding[]
  diagnosticSynthesis DiagnosticSynthesis?
  documentChunks    DocumentChunk[]
  evidenceDocuments EvidenceDocument[]
  consentRecords    ConsentRecord[]
  createdBy         User                  @relation(fields: [createdById], references: [id])
  organization      Organization          @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([createdAt])
  @@index([isExample])
  @@map("workshops")
}

model WorkshopShare {
  id          String   @id @default(cuid())
  workshopId  String
  userId      String
  sharedById  String
  createdAt   DateTime @default(now())

  workshop    Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workshopId, userId])
  @@index([userId])
  @@map("workshop_shares")
}

model TranscriptChunk {
  id             String           @id @default(cuid())
  workshopId     String
  speakerId      String?
  startTimeMs    BigInt
  endTimeMs      BigInt
  text           String
  confidence     Float?
  source         TranscriptSource
  metadata       Json?
  createdAt      DateTime         @default(now())
  // Lineage: set when this spoken record is assigned to a resolved thought window
  thoughtWindowId String?         @map("thought_window_id")
  dataPoint      DataPoint?
  workshop       Workshop         @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  thoughtWindow  ThoughtWindow?   @relation(fields: [thoughtWindowId], references: [id])

  @@unique([workshopId, startTimeMs, text], name: "workshopId_startTimeMs_text")
  @@index([workshopId])
  @@index([workshopId, startTimeMs])
  @@index([workshopId, createdAt])
  @@index([workshopId, speakerId, startTimeMs])
  @@index([thoughtWindowId])
  @@map("transcript_chunks")
}

// ThoughtWindow — server-side accumulation record.
// Opens when the first spoken record for a speaker arrives.
// Resolves when thought_completeness reaches 'complete' and the continuation
// window expires. A resolved window produces exactly one DataPoint.
// Expired windows retain their spoken records for audit but produce no DataPoint.
model ThoughtWindow {
  id                  String            @id @default(cuid())
  workshopId          String
  speakerId           String?
  state               ThoughtWindowState @default(OPEN)
  fullText            String            // live concatenation of all spoken records
  openedAtMs          BigInt
  lastActivityAtMs    BigInt
  closedAtMs          BigInt?
  pausedAtMs          BigInt?           // set when outgoing speaker's window is paused
  spokenRecordCount   Int               @default(0)
  resolvedText        String?           // final text passed to dataPoint creation
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  workshop            Workshop          @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  spokenRecords       TranscriptChunk[]
  dataPoint           DataPoint?

  @@index([workshopId])
  @@index([workshopId, speakerId, state])
  @@index([workshopId, state])
  @@map("thought_windows")
}

enum ThoughtWindowState {
  OPEN
  PAUSED
  RESOLVING
  RESOLVED
  EXPIRED
}

model DataPoint {
  id                  String                   @id @default(cuid())
  workshopId          String
  // Lineage — primary: the thought window that resolved into this record
  thoughtWindowId     String?                  @unique @map("thought_window_id")
  // Lineage — secondary: ordered IDs of all spoken records that contributed
  // Kept as a JSON array rather than a join table to avoid query overhead on reads.
  // The ThoughtWindow.spokenRecords relation is the authoritative join.
  spokenRecordIds     String[]                 @map("spoken_record_ids")
  // Legacy 1:1 link — retained for backward compat with existing records only.
  // New records must not use this field; use thoughtWindowId instead.
  transcriptChunkId   String?                  @unique @map("transcript_chunk_id")
  rawText             String
  source              DataPointSource
  speakerId           String?
  startTimeMs         BigInt?                  @map("start_time_ms")
  endTimeMs           BigInt?                  @map("end_time_ms")
  spanMs              Int?                     @map("span_ms")
  spokenRecordCount   Int?                     @default(1) @map("spoken_record_count")
  createdAt           DateTime                 @default(now())
  sessionId           String?
  participantId       String?
  questionKey         String?
  classification      DataPointClassification?
  annotation          DataPointAnnotation?
  agenticAnalysis     AgenticAnalysis?
  participant         WorkshopParticipant?     @relation(fields: [participantId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "data_points_participantid_fkey")
  session             ConversationSession?     @relation(fields: [sessionId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "data_points_sessionid_fkey")
  transcriptChunk     TranscriptChunk?         @relation(fields: [transcriptChunkId], references: [id])
  thoughtWindow       ThoughtWindow?           @relation(fields: [thoughtWindowId], references: [id])
  workshop            Workshop                 @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@unique([sessionId, questionKey], map: "data_points_sessionid_questionkey_key")
  @@index([workshopId])
  @@index([sessionId])
  @@index([participantId])
  @@index([workshopId, createdAt])
  @@index([thoughtWindowId])
  @@map("data_points")
}

model DataPointClassification {
  id            String               @id @default(cuid())
  dataPointId   String               @unique
  primaryType   DataPointPrimaryType
  confidence    Float?
  keywords      String[]
  suggestedArea String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  dataPoint     DataPoint            @relation(fields: [dataPointId], references: [id], onDelete: Cascade)

  @@index([dataPointId])
  @@map("data_point_classifications")
}

enum DialoguePhase {
  REIMAGINE
  CONSTRAINTS
  DEFINE_APPROACH
}

model DataPointAnnotation {
  id            String        @id @default(cuid())
  dataPointId   String        @unique
  dialoguePhase DialoguePhase?
  intent        String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  dataPoint DataPoint @relation(fields: [dataPointId], references: [id], onDelete: Cascade)

  @@index([dataPointId])
  @@map("data_point_annotations")
}

model AgenticAnalysis {
  id                 String   @id @default(cuid())
  dataPointId        String   @unique

  // Agent's interpretation
  semanticMeaning    String   // What the agent understood this to mean
  speakerIntent      String   // What the speaker was trying to do
  temporalFocus      String   // past, present, future, timeless
  sentimentTone      String   // positive, neutral, concerned, critical

  // Domain assignments with reasoning (stored as JSON)
  domains            Json     // Array of {domain, relevance, reasoning}

  // Themes identified (stored as JSON)
  themes             Json     // Array of {label, category, confidence, reasoning}

  // Connections to other utterances (stored as JSON)
  connections        Json     // Array of {type, targetUtteranceId, reasoning}

  // Business actors/roles mentioned (stored as JSON)
  actors             Json?    // Array of {name, role, interactions: [{withActor, action, sentiment, context}]}

  // Agent confidence and uncertainties
  overallConfidence  Float
  uncertainties      String[] // What the agent is unsure about

  // Metadata
  agentModel         String   // Which AI model was used
  analysisVersion    String   @default("1.0")
  createdAt          DateTime @default(now())

  dataPoint          DataPoint @relation(fields: [dataPointId], references: [id], onDelete: Cascade)

  @@map("agentic_analyses")
}

model WorkshopParticipant {
  id                    String                @id @default(cuid())
  workshopId            String
  email                 String
  name                  String
  role                  String?
  department            String?
  discoveryToken        String                @unique @default(cuid())
  attributionPreference AttributionPreference @default(NAMED)
  emailSentAt           DateTime?
  doNotSendAgain        Boolean               @default(false)
  responseStartedAt     DateTime?
  responseCompletedAt   DateTime?
  reminderSentAt        DateTime?
  createdAt             DateTime              @default(now())
  insights              ConversationInsight[]
  sessions              ConversationSession[]
  reports               ConversationReport[]
  dataPoints            DataPoint[]
  consentRecords        ConsentRecord[]
  workshop              Workshop              @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@index([workshopId])
  @@index([email])
  @@index([workshopId, responseCompletedAt])
  @@map("workshop_participants")
}

model ConversationSession {
  id                String                @id @default(cuid())
  workshopId        String
  participantId     String
  status            ConversationStatus    @default(IN_PROGRESS)
  runType           ConversationRunType   @default(BASELINE)
  questionSetVersion String               @default("v1")
  currentPhase      String                @default("intro")
  phaseProgress     Int                   @default(0)
  startedAt         DateTime              @default(now())
  completedAt       DateTime?
  totalDurationMs   Int?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  language          String                @default("en")
  voiceEnabled      Boolean               @default(false)
  includeRegulation Boolean               @default(true)
  insights          ConversationInsight[]
  report            ConversationReport?
  messages          ConversationMessage[]
  participant       WorkshopParticipant   @relation(fields: [participantId], references: [id], onDelete: Cascade)
  workshop          Workshop              @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  dataPoints        DataPoint[]

  @@index([workshopId])
  @@index([participantId])
  @@index([workshopId, status])
  @@index([workshopId, completedAt])
  @@map("conversation_sessions")
}

model ConversationMessage {
  id        String              @id @default(cuid())
  sessionId String
  role      MessageRole
  content   String
  phase     String?
  metadata  Json?
  createdAt DateTime            @default(now())
  session   ConversationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("conversation_messages")
}

model ConversationInsight {
  id               String                 @id @default(cuid())
  sessionId        String
  workshopId       String
  participantId    String
  insightType      InsightType
  category         InsightCategory?
  text             String
  severity         Int?
  impact           String?
  sourceMessageIds String[]
  confidence       Float                  @default(0.8)
  embedding        Unsupported("vector")?
  createdAt        DateTime               @default(now())
  participant      WorkshopParticipant    @relation(fields: [participantId], references: [id], onDelete: Cascade)
  session          ConversationSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  workshop         Workshop               @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@index([workshopId])
  @@index([sessionId])
  @@index([participantId])
  @@index([workshopId, insightType])
  @@map("conversation_insights")
}

model ConversationReport {
  id               String              @id @default(cuid())
  sessionId        String              @unique
  workshopId       String
  participantId    String
  executiveSummary String
  tone             String?
  feedback         String
  inputQuality     Json?
  keyInsights      Json?
  phaseInsights    Json?
  wordCloudThemes  Json?
  modelVersion     String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  participant      WorkshopParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  session          ConversationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  workshop         Workshop            @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@index([workshopId])
  @@index([participantId])
  @@map("conversation_reports")
}

model DiscoveryTheme {
  id               String   @id @default(cuid())
  workshopId       String
  themeLabel       String
  themeDescription String?
  participantCount Int      @default(0)
  responseIds      String[]
  confidence       Float    @default(0.8)
  modelVersion     String?
  createdAt        DateTime @default(now())
  workshop         Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@index([workshopId])
  @@map("discovery_themes")
}

model LiveWorkshopSnapshot {
  id           String   @id @default(cuid())
  workshopId   String
  name         String
  dialoguePhase String
  payload      Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workshop Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@index([workshopId, createdAt])
  @@map("live_workshop_snapshots")
}

model LiveSessionVersion {
  id            String   @id @default(cuid())
  workshopId    String
  version       Int
  dialoguePhase String
  payload       Json
  label         String?
  sizeBytes     Int      @default(0)
  createdAt     DateTime @default(now())

  workshop Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@unique([workshopId, version])
  @@index([workshopId, createdAt])
  @@map("live_session_versions")
}

model WorkshopEventOutbox {
  id         String   @id @default(cuid())
  workshopId String
  type       String
  payload    Json
  createdAt  DateTime @default(now())

  workshop Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@index([workshopId, createdAt])
  @@index([workshopId, type, createdAt])
  @@map("workshop_event_outbox")
}

model WorkshopScratchpad {
  id                String   @id @default(cuid())
  workshopId        String   @unique
  version           Int      @default(1)

  // Executive Summary Tab
  execSummary       Json?    // Vision, strategic shifts, today's challenge, future state principles

  // Discovery Output Tab
  discoveryOutput   Json?    // Strategic tables, design principles, linked intelligence

  // Reimagine Tab
  reimagineContent  Json?    // Strategic tables for reimagine phase

  // Constraints Tab
  constraintsContent Json?   // Strategic tables for constraints

  // Potential Solution Tab
  potentialSolution  Json?   // Enablers, actions, priority matrix, implementation path

  // Commercial Tab (password protected)
  commercialContent  Json?   // Delivery phases, investment summary, what gets built
  commercialPassword String? // Hashed password for commercial tab access

  // Customer Journey Tab
  customerJourney    Json?   // Actor swim-lanes, editable journey map, pain points

  // Summary Tab
  summaryContent     Json?   // Final summary and next steps

  // Images
  clientLogoUrl      String?  // URL to uploaded client logo
  solutionImageUrl   String?  // URL to uploaded solution overview image

  // V2 Output (knowledge-pack-anchored structured output)
  v2Output           Json?    @map("v2_output")  // V2Output: discover/reimagine/constraints/pathForward/outcomes/futureView

  // Output Assessment (archetype classification from deterministic classifier)
  outputAssessment   Json?    // { archetype, secondaryArchetypes, confidence, rationale, requiredSections }

  // Metadata
  generatedFromSnapshot String? // ID of LiveWorkshopSnapshot used to generate
  status            ScratchpadStatus @default(DRAFT)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  publishedAt       DateTime?

  workshop Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@map("workshop_scratchpads")
}

enum ScratchpadStatus {
  DRAFT
  IN_REVIEW
  PUBLISHED
}

enum WorkshopStatus {
  DRAFT
  DISCOVERY_SENT
  IN_PROGRESS
  COMPLETED
}

enum DreamTrack {
  ENTERPRISE    // Full end-to-end business assessment
  DOMAIN        // Focused on a specific business unit or function
}

enum WorkshopType {
  STRATEGY
  PROCESS
  CHANGE
  TEAM
  CUSTOMER
  INNOVATION
  CULTURE
  CUSTOM
  SALES
}

enum AttributionPreference {
  NAMED
  ANONYMOUS
}

enum ConversationStatus {
  IN_PROGRESS
  PAUSED
  COMPLETED
}

enum MessageRole {
  AI
  PARTICIPANT
}

enum ConversationRunType {
  BASELINE
  FOLLOWUP
}

enum InsightType {
  ACTUAL_JOB
  WHAT_WORKS
  CHALLENGE
  CONSTRAINT
  VISION
  BELIEF
  RATING
}

enum InsightCategory {
  BUSINESS
  TECHNOLOGY
  PEOPLE
  CUSTOMER
  REGULATION
}

enum TranscriptSource {
  ZOOM
  DEEPGRAM
  WHISPER
}

enum DataPointSource {
  SPEECH
  MANUAL
}

enum DataPointPrimaryType {
  VISIONARY
  OPPORTUNITY
  CONSTRAINT
  RISK
  ENABLER
  ACTION
  QUESTION
  INSIGHT
}

// Audit Log for GDPR/ISO 27001 Compliance
model AuditLog {
  id             String    @id
  organizationId String
  userId         String?
  userEmail      String?
  action         String
  resourceType   String?
  resourceId     String?
  method         String?
  path           String?
  ipAddress      String?
  userAgent      String?
  metadata       Json?
  timestamp      DateTime  @default(now())
  success        Boolean   @default(true)
  errorMessage   String?

  @@index([organizationId, timestamp(sort: Desc)])
  @@index([userId, timestamp(sort: Desc)])
  @@index([resourceType, resourceId])
  @@index([action])
  @@index([timestamp(sort: Desc)])
  @@map("audit_logs")
}

// ═══════════════════════════════════════════════════════════════
// Field Discovery / Diagnostic Extension
// ═══════════════════════════════════════════════════════════════

enum EngagementType {
  DIAGNOSTIC_BASELINE
  OPERATIONAL_DEEP_DIVE
  AI_ENABLEMENT
  TRANSFORMATION_SPRINT
  CULTURAL_ALIGNMENT
  GO_TO_MARKET
}

enum CaptureType {
  WALKAROUND
  EXECUTIVE_INTERVIEW
  MANAGER_INTERVIEW
  OPERATIONAL_INTERVIEW
}

enum CaptureSessionStatus {
  OPEN
  RECORDING
  PAUSED
  UPLOADED
  TRANSCRIBED
  ANALYSED
}

enum FindingType {
  CONSTRAINT
  OPPORTUNITY
  RISK
  CONTRADICTION
}

enum SourceStream {
  STREAM_A   // Remote / AI-led discovery (existing)
  STREAM_B   // Field capture (new)
}

model CaptureSession {
  id              String               @id @default(cuid())
  workshopId      String
  captureType     CaptureType
  actorRole       String?              // From domain pack actor taxonomy
  area            String?              // Department or physical area
  department      String?
  participantName String?              // Optional name (consent-dependent)
  consentFlag     Boolean              @default(false)
  status          CaptureSessionStatus @default(OPEN)
  deviceType      String?              // "desktop" or "mobile"
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  segments        CaptureSegment[]
  findings        Finding[]
  workshop        Workshop             @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@index([workshopId])
  @@index([workshopId, status])
  @@index([workshopId, captureType])
  @@map("capture_sessions")
}

model CaptureSegment {
  id                  String   @id @default(cuid())
  captureSessionId    String
  segmentIndex        Int
  startTimeMs         BigInt?
  endTimeMs           BigInt?
  audioReference      String?  // Storage path or URL for audio file
  transcriptReference String?  // Storage path or URL for transcript
  transcript          String?  // Full transcript text
  status              String   @default("pending") // pending, uploaded, transcribed
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  captureSession CaptureSession @relation(fields: [captureSessionId], references: [id], onDelete: Cascade)

  @@index([captureSessionId])
  @@map("capture_segments")
}

model Finding {
  id                  String       @id @default(cuid())
  workshopId          String
  captureSessionId    String?
  sourceStream        SourceStream
  lens                String       // People, Organisation, Customer, Technology, Regulation
  type                FindingType
  title               String
  description         String
  severityScore       Float?       // 0-10 scale
  frequencyCount      Int          @default(1)
  roleCoverage        String[]     // Which actor roles surfaced this
  supportingQuotes    Json?        // Array of {text, sessionId, segmentIndex}
  confidenceScore     Float?       // 0-1 scale
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  captureSession CaptureSession? @relation(fields: [captureSessionId], references: [id], onDelete: SetNull)
  workshop       Workshop        @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@index([workshopId])
  @@index([workshopId, sourceStream])
  @@index([workshopId, lens])
  @@index([workshopId, type])
  @@map("findings")
}

model DiagnosticSynthesis {
  id                String   @id @default(cuid())
  workshopId        String   @unique
  lensSummaries     Json?    // Per-lens: themes, evidence density, severity, role distribution, quick wins
  crossLens         Json?    // Structural weaknesses, systemic risks, contradictions, 30/90 day actions
  streamComparison  Json?    // Per-lens: declared perception (A), observed reality (B), alignment gap
  sessionsProcessed Int      @default(0)
  version           Int      @default(1)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  workshop Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@map("diagnostic_syntheses")
}

model DocumentChunk {
  id            String    @id @default(cuid())
  workshopId    String    @map("workshop_id")
  fileName      String    @map("file_name")
  fileType      String    @map("file_type")        // "pdf","docx","txt","image","video"
  fileSizeBytes Int       @map("file_size_bytes")
  storageKey    String    @map("storage_key")       // path in object storage
  chunkIndex    Int       @map("chunk_index")
  totalChunks   Int       @map("total_chunks")
  content       String                              // text content, transcription, or Vision description
  pageNumber    Int?      @map("page_number")       // PDFs only
  artefactType  String?   @map("artefact_type")     // "whiteboard"|"sticky_notes"|"diagram"|"handwritten"|"photo"|"transcript"|"document"|"video"
  embedding     Unsupported("vector")?              // matches pgvector column added via SQL
  createdAt     DateTime  @default(now())           @map("created_at")

  workshop      Workshop  @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@index([workshopId])
  @@map("document_chunks")
}

model EvidenceDocument {
  id               String   @id @default(cuid())
  workshopId       String   @map("workshop_id")
  originalFileName String   @map("original_file_name")
  mimeType         String   @map("mime_type")
  fileSizeBytes    Int      @map("file_size_bytes")
  storageKey       String   @map("storage_key")

  status           String   @default("uploading")
  errorMessage     String?  @map("error_message")

  sourceCategory   String?  @map("source_category")
  summary          String?
  timeframeFrom    String?  @map("timeframe_from")
  timeframeTo      String?  @map("timeframe_to")

  findings         Json?
  metrics          Json?
  excerpts         Json?

  signalDirection  String?  @map("signal_direction")
  confidence       Float?

  relevantLenses         Json? @map("relevant_lenses")
  relevantActors         Json? @map("relevant_actors")
  relevantJourneyStages  Json? @map("relevant_journey_stages")

  crossValidation  Json?  @map("cross_validation")

  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt     @map("updated_at")

  workshop         Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@index([workshopId])
  @@index([workshopId, status])
  @@map("evidence_documents")
}

model AnalyticsEvent {
  id          String   @id @default(cuid())
  type        String
  visitorId   String   @map("visitor_id")
  sessionId   String   @map("session_id")
  pagePath    String   @map("page_path")
  pageTitle   String?  @map("page_title")
  referrer    String?
  deviceType  String?  @map("device_type")
  durationMs  Int?     @map("duration_ms")
  country     String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([visitorId])
  @@index([sessionId])
  @@index([pagePath])
  @@map("analytics_events")
}

// ═══════════════════════════════════════════════════════════════
// GDPR Consent Records (Art. 7 + Art. 9 — lawful basis evidence)
// ═══════════════════════════════════════════════════════════════

enum ConsentPurpose {
  WORKSHOP_PARTICIPATION    // Participant consents to voice/text capture during a workshop
  DISCOVERY_CONVERSATION    // Participant consents to discovery conversation data processing
  AUDIO_RECORDING           // Explicit consent for audio recording + AI transcription
  DATA_RETENTION            // Consent to store session data beyond the immediate workshop
  MARKETING                 // Consent to receive marketing communications (landing page)
}

enum ConsentChannel {
  WEB_FORM                  // Discovery participant landing page form
  CAPTURE_MOBILE            // Mobile capture session consent flag
  ADMIN_RECORDED            // Admin records offline consent on participant's behalf
}

model ConsentRecord {
  id              String          @id @default(cuid())
  // Participant identifier — may be anonymous before a User account exists
  participantId   String?         @map("participant_id")
  email           String?         // Nullable: anonymous participants may not provide email
  workshopId      String?         @map("workshop_id")   // Which workshop this consent covers
  purpose         ConsentPurpose
  channel         ConsentChannel
  // Consent text exactly as presented to the participant at time of capture
  consentText     String          @map("consent_text")
  // Version of the consent form/privacy notice shown (e.g. "v1.2")
  consentVersion  String          @default("1.0") @map("consent_version")
  granted         Boolean         // true = consented, false = explicitly declined/withdrawn
  grantedAt       DateTime?       @map("granted_at")
  withdrawnAt     DateTime?       @map("withdrawn_at")
  // IP address and user agent at time of consent (Art.7 evidentiary requirement)
  ipAddress       String?         @map("ip_address")
  userAgent       String?         @map("user_agent")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt      @map("updated_at")

  participant     WorkshopParticipant? @relation(fields: [participantId], references: [id], onDelete: SetNull)
  workshop        Workshop?            @relation(fields: [workshopId], references: [id], onDelete: SetNull)

  @@index([participantId])
  @@index([workshopId])
  @@index([email])
  @@index([purpose, granted])
  @@index([createdAt])
  @@map("consent_records")
}
