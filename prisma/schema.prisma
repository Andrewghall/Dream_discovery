generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [uuid_ossp(map: "uuid-ossp", schema: "extensions"), vector]
}

model Organization {
  id             String     @id @default(cuid())
  name           String
  logoUrl        String?    // URL or path to org logo
  primaryColor   String?    // e.g. "#4a90a4"
  secondaryColor String?    // e.g. "#7C3AED"
  maxSeats       Int        @default(5)   // licence seat limit
  billingEmail   String?    // billing contact email
  adminName      String?    // admin contact first name (used in onboarding email)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  users          User[]
  workshops      Workshop[]

  @@map("organizations")
}

model User {
  id               String       @id @default(cuid())
  email            String       @unique
  name             String
  password         String       // bcrypt hashed password
  mustChangePassword Boolean    @default(false) @map("must_change_password")
  role             UserRole     @default(TENANT_ADMIN)
  organizationId   String?      // NULL for platform admins
  isActive         Boolean      @default(true)
  lastLoginAt      DateTime?
  failedLoginCount Int          @default(0)
  lockedUntil      DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  organization     Organization? @relation(fields: [organizationId], references: [id])
  createdWorkshops Workshop[]
  workshopShares   WorkshopShare[]
  loginAttempts    LoginAttempt[]
  sessions         Session[]
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

enum UserRole {
  PLATFORM_ADMIN  // Can see all organizations
  TENANT_ADMIN    // Can only see their organization; can manage sub-users
  TENANT_USER     // Can run workshops but cannot manage users
}

model LoginAttempt {
  id          String   @id @default(cuid())
  userId      String?  // NULL if user not found
  email       String
  ipAddress   String?
  userAgent   String?
  success     Boolean
  failureReason String?
  createdAt   DateTime @default(now())
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, createdAt])
  @@index([success, createdAt])
  @@map("login_attempts")
}

model Session {
  id             String    @id @default(cuid())
  userId         String
  token          String    @unique
  userAgent      String?
  ipAddress      String?
  expiresAt      DateTime
  lastActivityAt DateTime  @default(now())
  createdAt      DateTime  @default(now())
  revokedAt      DateTime?
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@index([userId, expiresAt])
  @@map("sessions")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model Workshop {
  id                String                @id @default(cuid())
  organizationId    String
  name              String
  description       String?
  businessContext   String?
  workshopType      WorkshopType          @default(CUSTOM)
  status            WorkshopStatus        @default(DRAFT)
  zoomMeetingId     String?
  createdById       String
  scheduledDate     DateTime?
  responseDeadline  DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  includeRegulation Boolean               @default(true)
  meetingPlan       Json?
  salesReport       Json?
  salesActions      Json?

  // DREAM workshop prep fields
  clientName        String?               @map("client_name")          // e.g. "Tesco", "Barclays"
  industry          String?                                            // e.g. "Retail", "Financial Services"
  companyWebsite    String?               @map("company_website")      // e.g. "https://www.tesco.com"
  dreamTrack        DreamTrack?           @map("dream_track")          // ENTERPRISE or DOMAIN
  targetDomain      String?               @map("target_domain")        // e.g. "Customer Operations" (DOMAIN track only)
  prepResearch      Json?                 @map("prep_research")        // Research Agent output
  customQuestions   Json?                 @map("custom_questions")     // Tailored question set (editable)
  discoveryBriefing Json?                 @map("discovery_briefing")   // Discovery Intelligence Agent synthesis
  discoverAnalysis  Json?                 @map("discover_analysis")    // Organisational Analysis dashboard data
  discoverySummary  Json?                 @map("discovery_summary")    // Cached discovery summary (executive + lenses)

  // Field Discovery / Diagnostic extension fields
  engagementType      EngagementType?       @map("engagement_type")      // Diagnostic Baseline, Operational Deep Dive, etc.
  domainPack          String?               @map("domain_pack")          // Key into domain pack registry (e.g. "contact_centre")
  domainPackConfig    Json?                 @map("domain_pack_config")   // Resolved config snapshot at creation time
  discoveryQuestions  Json?                 @map("discovery_questions")  // Per-lens Discovery interview questions (editable)
  blueprint           Json?                 @map("blueprint")            // Composed WorkshopBlueprint snapshot (runtime config)
  historicalMetrics   Json?                 @map("historical_metrics")   // Normalized metric time series from CSV upload

  insights          ConversationInsight[]
  sessions          ConversationSession[]
  dataPoints        DataPoint[]
  reports           ConversationReport[]
  themes            DiscoveryTheme[]
  liveSnapshots     LiveWorkshopSnapshot[]
  sessionVersions   LiveSessionVersion[]
  eventOutbox       WorkshopEventOutbox[]
  transcriptChunks  TranscriptChunk[]
  participants      WorkshopParticipant[]
  scratchpad        WorkshopScratchpad?
  shares            WorkshopShare[]
  captureSessions   CaptureSession[]
  findings          Finding[]
  diagnosticSynthesis DiagnosticSynthesis?
  createdBy         User                  @relation(fields: [createdById], references: [id])
  organization      Organization          @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([createdAt])
  @@map("workshops")
}

model WorkshopShare {
  id          String   @id @default(cuid())
  workshopId  String
  userId      String
  sharedById  String
  createdAt   DateTime @default(now())

  workshop    Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workshopId, userId])
  @@index([userId])
  @@map("workshop_shares")
}

model TranscriptChunk {
  id          String           @id @default(cuid())
  workshopId  String
  speakerId   String?
  startTimeMs BigInt
  endTimeMs   BigInt
  text        String
  confidence  Float?
  source      TranscriptSource
  metadata    Json?
  createdAt   DateTime         @default(now())
  dataPoint   DataPoint?
  workshop    Workshop         @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@index([workshopId])
  @@index([workshopId, createdAt])
  @@map("transcript_chunks")
}

model DataPoint {
  id                String                   @id @default(cuid())
  workshopId        String
  transcriptChunkId String?                  @unique
  rawText           String
  source            DataPointSource
  speakerId         String?
  createdAt         DateTime                 @default(now())
  sessionId         String?
  participantId     String?
  questionKey       String?
  classification    DataPointClassification?
  annotation        DataPointAnnotation?
  agenticAnalysis   AgenticAnalysis?
  participant       WorkshopParticipant?     @relation(fields: [participantId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "data_points_participantid_fkey")
  session           ConversationSession?     @relation(fields: [sessionId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "data_points_sessionid_fkey")
  transcriptChunk   TranscriptChunk?         @relation(fields: [transcriptChunkId], references: [id])
  workshop          Workshop                 @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@unique([sessionId, questionKey], map: "data_points_sessionid_questionkey_key")
  @@index([workshopId])
  @@index([sessionId])
  @@index([participantId])
  @@index([workshopId, createdAt])
  @@map("data_points")
}

model DataPointClassification {
  id            String               @id @default(cuid())
  dataPointId   String               @unique
  primaryType   DataPointPrimaryType
  confidence    Float?
  keywords      String[]
  suggestedArea String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  dataPoint     DataPoint            @relation(fields: [dataPointId], references: [id], onDelete: Cascade)

  @@index([dataPointId])
  @@map("data_point_classifications")
}

enum DialoguePhase {
  REIMAGINE
  CONSTRAINTS
  DEFINE_APPROACH
}

model DataPointAnnotation {
  id            String        @id @default(cuid())
  dataPointId   String        @unique
  dialoguePhase DialoguePhase?
  intent        String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  dataPoint DataPoint @relation(fields: [dataPointId], references: [id], onDelete: Cascade)

  @@index([dataPointId])
  @@map("data_point_annotations")
}

model AgenticAnalysis {
  id                 String   @id @default(cuid())
  dataPointId        String   @unique

  // Agent's interpretation
  semanticMeaning    String   // What the agent understood this to mean
  speakerIntent      String   // What the speaker was trying to do
  temporalFocus      String   // past, present, future, timeless
  sentimentTone      String   // positive, neutral, concerned, critical

  // Domain assignments with reasoning (stored as JSON)
  domains            Json     // Array of {domain, relevance, reasoning}

  // Themes identified (stored as JSON)
  themes             Json     // Array of {label, category, confidence, reasoning}

  // Connections to other utterances (stored as JSON)
  connections        Json     // Array of {type, targetUtteranceId, reasoning}

  // Business actors/roles mentioned (stored as JSON)
  actors             Json?    // Array of {name, role, interactions: [{withActor, action, sentiment, context}]}

  // Agent confidence and uncertainties
  overallConfidence  Float
  uncertainties      String[] // What the agent is unsure about

  // Metadata
  agentModel         String   // Which AI model was used
  analysisVersion    String   @default("1.0")
  createdAt          DateTime @default(now())

  dataPoint          DataPoint @relation(fields: [dataPointId], references: [id], onDelete: Cascade)

  @@map("agentic_analyses")
}

model WorkshopParticipant {
  id                    String                @id @default(cuid())
  workshopId            String
  email                 String
  name                  String
  role                  String?
  department            String?
  discoveryToken        String                @unique @default(cuid())
  attributionPreference AttributionPreference @default(NAMED)
  emailSentAt           DateTime?
  doNotSendAgain        Boolean               @default(false)
  responseStartedAt     DateTime?
  responseCompletedAt   DateTime?
  reminderSentAt        DateTime?
  createdAt             DateTime              @default(now())
  insights              ConversationInsight[]
  sessions              ConversationSession[]
  reports               ConversationReport[]
  dataPoints            DataPoint[]
  workshop              Workshop              @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@index([workshopId])
  @@index([email])
  @@index([workshopId, responseCompletedAt])
  @@map("workshop_participants")
}

model ConversationSession {
  id                String                @id @default(cuid())
  workshopId        String
  participantId     String
  status            ConversationStatus    @default(IN_PROGRESS)
  runType           ConversationRunType   @default(BASELINE)
  questionSetVersion String               @default("v1")
  currentPhase      String                @default("intro")
  phaseProgress     Int                   @default(0)
  startedAt         DateTime              @default(now())
  completedAt       DateTime?
  totalDurationMs   Int?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  language          String                @default("en")
  voiceEnabled      Boolean               @default(false)
  includeRegulation Boolean               @default(true)
  insights          ConversationInsight[]
  report            ConversationReport?
  messages          ConversationMessage[]
  participant       WorkshopParticipant   @relation(fields: [participantId], references: [id], onDelete: Cascade)
  workshop          Workshop              @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  dataPoints        DataPoint[]

  @@index([workshopId])
  @@index([participantId])
  @@index([workshopId, status])
  @@index([workshopId, completedAt])
  @@map("conversation_sessions")
}

model ConversationMessage {
  id        String              @id @default(cuid())
  sessionId String
  role      MessageRole
  content   String
  phase     String?
  metadata  Json?
  createdAt DateTime            @default(now())
  session   ConversationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("conversation_messages")
}

model ConversationInsight {
  id               String                 @id @default(cuid())
  sessionId        String
  workshopId       String
  participantId    String
  insightType      InsightType
  category         InsightCategory?
  text             String
  severity         Int?
  impact           String?
  sourceMessageIds String[]
  confidence       Float                  @default(0.8)
  embedding        Unsupported("vector")?
  createdAt        DateTime               @default(now())
  participant      WorkshopParticipant    @relation(fields: [participantId], references: [id], onDelete: Cascade)
  session          ConversationSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  workshop         Workshop               @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@index([workshopId])
  @@index([sessionId])
  @@index([participantId])
  @@index([workshopId, insightType])
  @@map("conversation_insights")
}

model ConversationReport {
  id               String              @id @default(cuid())
  sessionId        String              @unique
  workshopId       String
  participantId    String
  executiveSummary String
  tone             String?
  feedback         String
  inputQuality     Json?
  keyInsights      Json?
  phaseInsights    Json?
  wordCloudThemes  Json?
  modelVersion     String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  participant      WorkshopParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  session          ConversationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  workshop         Workshop            @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@index([workshopId])
  @@index([participantId])
  @@map("conversation_reports")
}

model DiscoveryTheme {
  id               String   @id @default(cuid())
  workshopId       String
  themeLabel       String
  themeDescription String?
  participantCount Int      @default(0)
  responseIds      String[]
  confidence       Float    @default(0.8)
  modelVersion     String?
  createdAt        DateTime @default(now())
  workshop         Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@index([workshopId])
  @@map("discovery_themes")
}

model LiveWorkshopSnapshot {
  id           String   @id @default(cuid())
  workshopId   String
  name         String
  dialoguePhase String
  payload      Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workshop Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@index([workshopId, createdAt])
  @@map("live_workshop_snapshots")
}

model LiveSessionVersion {
  id            String   @id @default(cuid())
  workshopId    String
  version       Int
  dialoguePhase String
  payload       Json
  label         String?
  sizeBytes     Int      @default(0)
  createdAt     DateTime @default(now())

  workshop Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@unique([workshopId, version])
  @@index([workshopId, createdAt])
  @@map("live_session_versions")
}

model WorkshopEventOutbox {
  id         String   @id @default(cuid())
  workshopId String
  type       String
  payload    Json
  createdAt  DateTime @default(now())

  workshop Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@index([workshopId, createdAt])
  @@index([workshopId, type, createdAt])
  @@map("workshop_event_outbox")
}

model WorkshopScratchpad {
  id                String   @id @default(cuid())
  workshopId        String   @unique
  version           Int      @default(1)

  // Executive Summary Tab
  execSummary       Json?    // Vision, strategic shifts, today's challenge, future state principles

  // Discovery Output Tab
  discoveryOutput   Json?    // Strategic tables, design principles, linked intelligence

  // Reimagine Tab
  reimagineContent  Json?    // Strategic tables for reimagine phase

  // Constraints Tab
  constraintsContent Json?   // Strategic tables for constraints

  // Potential Solution Tab
  potentialSolution  Json?   // Enablers, actions, priority matrix, implementation path

  // Commercial Tab (password protected)
  commercialContent  Json?   // Delivery phases, investment summary, what gets built
  commercialPassword String? // Hashed password for commercial tab access

  // Customer Journey Tab
  customerJourney    Json?   // Actor swim-lanes, editable journey map, pain points

  // Summary Tab
  summaryContent     Json?   // Final summary and next steps

  // Images
  clientLogoUrl      String?  // URL to uploaded client logo
  solutionImageUrl   String?  // URL to uploaded solution overview image

  // Output Assessment (archetype classification from deterministic classifier)
  outputAssessment   Json?    // { archetype, secondaryArchetypes, confidence, rationale, requiredSections }

  // Metadata
  generatedFromSnapshot String? // ID of LiveWorkshopSnapshot used to generate
  status            ScratchpadStatus @default(DRAFT)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  publishedAt       DateTime?

  workshop Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@map("workshop_scratchpads")
}

enum ScratchpadStatus {
  DRAFT
  IN_REVIEW
  PUBLISHED
}

enum WorkshopStatus {
  DRAFT
  DISCOVERY_SENT
  IN_PROGRESS
  COMPLETED
}

enum DreamTrack {
  ENTERPRISE    // Full end-to-end business assessment
  DOMAIN        // Focused on a specific business unit or function
}

enum WorkshopType {
  STRATEGY
  PROCESS
  CHANGE
  TEAM
  CUSTOMER
  INNOVATION
  CULTURE
  CUSTOM
  SALES
}

enum AttributionPreference {
  NAMED
  ANONYMOUS
}

enum ConversationStatus {
  IN_PROGRESS
  PAUSED
  COMPLETED
}

enum MessageRole {
  AI
  PARTICIPANT
}

enum ConversationRunType {
  BASELINE
  FOLLOWUP
}

enum InsightType {
  ACTUAL_JOB
  WHAT_WORKS
  CHALLENGE
  CONSTRAINT
  VISION
  BELIEF
  RATING
}

enum InsightCategory {
  BUSINESS
  TECHNOLOGY
  PEOPLE
  CUSTOMER
  REGULATION
}

enum TranscriptSource {
  ZOOM
  DEEPGRAM
  WHISPER
}

enum DataPointSource {
  SPEECH
  MANUAL
}

enum DataPointPrimaryType {
  VISIONARY
  OPPORTUNITY
  CONSTRAINT
  RISK
  ENABLER
  ACTION
  QUESTION
  INSIGHT
}

// Audit Log for GDPR/ISO 27001 Compliance
model AuditLog {
  id             String    @id
  organizationId String
  userId         String?
  userEmail      String?
  action         String
  resourceType   String?
  resourceId     String?
  method         String?
  path           String?
  ipAddress      String?
  userAgent      String?
  metadata       Json?
  timestamp      DateTime  @default(now())
  success        Boolean   @default(true)
  errorMessage   String?

  @@index([organizationId, timestamp(sort: Desc)])
  @@index([userId, timestamp(sort: Desc)])
  @@index([resourceType, resourceId])
  @@index([action])
  @@index([timestamp(sort: Desc)])
  @@map("audit_logs")
}

// ═══════════════════════════════════════════════════════════════
// Field Discovery / Diagnostic Extension
// ═══════════════════════════════════════════════════════════════

enum EngagementType {
  DIAGNOSTIC_BASELINE
  OPERATIONAL_DEEP_DIVE
  AI_ENABLEMENT
  TRANSFORMATION_SPRINT
  CULTURAL_ALIGNMENT
}

enum CaptureType {
  WALKAROUND
  EXECUTIVE_INTERVIEW
  MANAGER_INTERVIEW
  OPERATIONAL_INTERVIEW
}

enum CaptureSessionStatus {
  OPEN
  RECORDING
  PAUSED
  UPLOADED
  TRANSCRIBED
  ANALYSED
}

enum FindingType {
  CONSTRAINT
  OPPORTUNITY
  RISK
  CONTRADICTION
}

enum SourceStream {
  STREAM_A   // Remote / AI-led discovery (existing)
  STREAM_B   // Field capture (new)
}

model CaptureSession {
  id              String               @id @default(cuid())
  workshopId      String
  captureType     CaptureType
  actorRole       String?              // From domain pack actor taxonomy
  area            String?              // Department or physical area
  department      String?
  participantName String?              // Optional name (consent-dependent)
  consentFlag     Boolean              @default(false)
  status          CaptureSessionStatus @default(OPEN)
  deviceType      String?              // "desktop" or "mobile"
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  segments        CaptureSegment[]
  findings        Finding[]
  workshop        Workshop             @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@index([workshopId])
  @@index([workshopId, status])
  @@index([workshopId, captureType])
  @@map("capture_sessions")
}

model CaptureSegment {
  id                  String   @id @default(cuid())
  captureSessionId    String
  segmentIndex        Int
  startTimeMs         BigInt?
  endTimeMs           BigInt?
  audioReference      String?  // Storage path or URL for audio file
  transcriptReference String?  // Storage path or URL for transcript
  transcript          String?  // Full transcript text
  status              String   @default("pending") // pending, uploaded, transcribed
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  captureSession CaptureSession @relation(fields: [captureSessionId], references: [id], onDelete: Cascade)

  @@index([captureSessionId])
  @@map("capture_segments")
}

model Finding {
  id                  String       @id @default(cuid())
  workshopId          String
  captureSessionId    String?
  sourceStream        SourceStream
  lens                String       // People, Organisation, Customer, Technology, Regulation
  type                FindingType
  title               String
  description         String
  severityScore       Float?       // 0-10 scale
  frequencyCount      Int          @default(1)
  roleCoverage        String[]     // Which actor roles surfaced this
  supportingQuotes    Json?        // Array of {text, sessionId, segmentIndex}
  confidenceScore     Float?       // 0-1 scale
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  captureSession CaptureSession? @relation(fields: [captureSessionId], references: [id], onDelete: SetNull)
  workshop       Workshop        @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@index([workshopId])
  @@index([workshopId, sourceStream])
  @@index([workshopId, lens])
  @@index([workshopId, type])
  @@map("findings")
}

model DiagnosticSynthesis {
  id                String   @id @default(cuid())
  workshopId        String   @unique
  lensSummaries     Json?    // Per-lens: themes, evidence density, severity, role distribution, quick wins
  crossLens         Json?    // Structural weaknesses, systemic risks, contradictions, 30/90 day actions
  streamComparison  Json?    // Per-lens: declared perception (A), observed reality (B), alignment gap
  sessionsProcessed Int      @default(0)
  version           Int      @default(1)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  workshop Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@map("diagnostic_syntheses")
}
