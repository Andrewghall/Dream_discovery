	left: auto;
	right: 30px;
	top: -20px;
	display: none;
}

.menuArea ul ul li.menu-item-has-children:first-child a:before {
	position: absolute;
	right: 30px;
	top: -20px;
	left: auto;
	content: "";
	border-color: #FFF transparent;
	border-width: 8px 8px 0 8px;
	border-style: solid;
}

