	margin-top: 3px;
	background-color: #fafafa;
	font-size: 14px;
}

body form.maForm input[type="radio"] {
	height: 17px;
	margin: 2px 7px 2px 4px;
}

body form.maForm input[type="checkbox"] {
	float: none;
	position: static;
	opacity: 1;
	width: inherit;
}

body form.maForm select {
	width: 100%;
	height: 39px;
}

form.maForm textarea {
    width: 100%;
}

