{
  "name": "@dream/slm-primitives",
  "version": "0.1.0",
  "description": "Local SLM inference primitives — classify, extract, generate, embed. No API keys, no tokens, fully offline.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./classify": {
      "import": "./dist/primitives/classify.js",
      "types": "./dist/primitives/classify.d.ts"
    },
    "./ner": {
      "import": "./dist/primitives/ner.js",
      "types": "./dist/primitives/ner.d.ts"
    },
    "./generate": {
      "import": "./dist/primitives/generate.js",
      "types": "./dist/primitives/generate.d.ts"
    },
    "./embed": {
      "import": "./dist/primitives/embed.js",
      "types": "./dist/primitives/embed.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --test dist/**/*.test.js"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.4.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
